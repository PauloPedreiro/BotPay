{
  "name": "botpay",
  "version": "1.0.0",
  "description": "Discord Donation Bot with Mercado Pago (PIX) and Stripe Integration",
  "main": "dist/bundle.cjs",
  "type": "module",
  "scripts": {
    "start": "node dist/bundle.cjs",
    "build": "esbuild src/index.js --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs && pkg . --targets node18-win-x64 --out-path dist"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.16.3",
    "express": "^4.19.2",
    "qrcode": "^1.5.3",
    "stripe": "^15.12.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1"
  },
  "bin": "dist/bundle.cjs",
  "pkg": {
    "assets": [
      "src/public/**/*"
    ]
  }
}
